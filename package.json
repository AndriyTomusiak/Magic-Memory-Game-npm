{
  "name": "ngx-magic-memory",
  "version": "1.0.0",
  "description": "A configurable memory card matching game for Angular 21+",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:lib": "ng build ngx-magic-memory",
    "prepare": "ng build ngx-magic-memory",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "exports": {
    ".": {
      "types": "./dist/ngx-magic-memory/types/ngx-magic-memory.d.ts",
      "default": "./dist/ngx-magic-memory/fesm2022/ngx-magic-memory.mjs"
    }
  },
  "type": "module",
  "typings": "dist/ngx-magic-memory/types/ngx-magic-memory.d.ts",
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.1",
    "@angular/cli": "^21.0.1",
    "@angular/compiler-cli": "^21.0.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}